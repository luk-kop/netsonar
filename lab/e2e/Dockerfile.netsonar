FROM golang:1.26-alpine AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -ldflags "-s -w -X 'main.version=e2e'" -o /out/netsonar ./cmd/agent

FROM alpine:3.22

RUN adduser -D -H -u 10001 netsonar
COPY --from=build /out/netsonar /usr/local/bin/netsonar

USER netsonar
ENTRYPOINT ["/usr/local/bin/netsonar"]
