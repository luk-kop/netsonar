      "title": "Probe Info - $target_name",
      "description": "Current probe metadata for the selected HTTP target. Path shows the raw proxy_name label value, for example direct or proxy.",
      "type": "table",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "url": true,
              "probe_type": true,
              "target_name": true,
              "monitor": true,
              "provider": true,
              "target_partition": true,
              "visibility": true
            },
            "indexByName": {
              "Value": 0,
              "target": 1,
              "proxy_name": 2,
              "impact": 3,
              "service": 4,
              "scope": 5,
              "target_type": 6,
              "target_region": 7,
              "target_account": 8
            },
            "renameByName": {
              "Value": "Status",
              "proxy_name": "Path",
              "target": "Target",
              "service": "Service",
              "scope": "Scope",
              "target_region": "Region",
              "target_account": "Account",
