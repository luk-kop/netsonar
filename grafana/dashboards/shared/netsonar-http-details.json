      "title": "Current",
      "description": "Latest total HTTP probe duration for the selected target, excluding hard-timeout results. Failed non-timeout probes are included. This is wall-clock probe time, including DNS, TCP, TLS, request write, TTFB, and capped response-body transfer.",
      "type": "stat",
      "targets": [
        {
          "expr": "probe_duration_seconds{job=~\"$job\", probe_type=\"http\", target_name=\"$target_name\"} unless on(job, target_name, proxy_name) (probe_timed_out{job=~\"$job\", probe_type=\"http\", target_name=\"$target_name\"} == 1)",
          "legendFormat": "",
          "refId": "A"
