  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Current",
      "description": "Latest total HTTP probe duration for the selected target. This is wall-clock probe time, including DNS, TCP, TLS, request write, TTFB, and capped response-body transfer.",
      "type": "stat",
      "targets": [
        {
          "expr": "probe_duration_seconds{job=~\"$job\", probe_type=\"http\", target_name=\"$target_name\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Mean (5m)",
      "description": "Mean total HTTP probe duration over the last 5 minutes for the selected target. Use this to smooth short spikes and compare against the current value.",
      "type": "stat",
      "targets": [
        {
          "expr": "avg_over_time(probe_duration_seconds{job=~\"$job\", probe_type=\"http\", target_name=\"$target_name\"}[5m])",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "p95 (5m)",
      "description": "95th percentile total HTTP probe duration over the last 5 minutes. Higher than the mean indicates intermittent latency spikes.",
      "type": "stat",
      "targets": [
        {
          "expr": "quantile_over_time(0.95, probe_duration_seconds{job=~\"$job\", probe_type=\"http\", target_name=\"$target_name\"}[5m])",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Max (5m)",
      "description": "Maximum total HTTP probe duration over the last 5 minutes. Useful for spotting timeout-adjacent probes or isolated slow runs.",
      "type": "stat",
      "targets": [
        {
          "expr": "max_over_time(probe_duration_seconds{job=~\"$job\", probe_type=\"http\", target_name=\"$target_name\"}[5m])",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 40,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "mode": "normal", "group": "A" }
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/^dns_resolve$/" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/^tcp_connect$/" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/^tls_handshake$/" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/^request_write$/" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "cyan" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/^ttfb$/" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/^transfer$/" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } }]
          }
        ]
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 4 },
      "id": 5,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        },
        "tooltip": { "mode": "multi" }
      },
      "title": "HTTP Phase Timing — $target_name",
      "description": "Stacked phase durations for the selected HTTP target. Phases are non-overlapping and sum ≈ probe_duration_seconds. Missing phases were not observed or do not apply.\n\nPhase legend:\n- dns_resolve: DNS lookup time for hostname targets.\n- tcp_connect: TCP connection establishment time.\n- tls_handshake: target TLS handshake time; absent for plain HTTP.\n- request_write: time from connection/TLS readiness to request write completion. Usually near-zero for GET/small requests; grows when request_body_bytes sends an upload payload.\n- ttfb: time from request write completion to first response byte.\n- transfer: response body read time up to response_body_limit_bytes.\n\nColors: dns_resolve (blue), tcp_connect (green), tls_handshake (yellow), request_write (cyan), ttfb (orange), transfer (purple).",
      "type": "timeseries",
      "targets": [
        {
          "expr": "probe_phase_duration_seconds{job=~\"$job\", probe_type=\"http\", target_name=\"$target_name\"}",
          "legendFormat": "{{phase}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 0,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "mode": "none", "group": "A" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "HTTP Status Codes — $target_name",
      "description": "HTTP response status code observed for the selected target. The series is present only when an HTTP response was received; DNS, TCP, TLS, request-write, or timeout failures can appear as no status-code sample.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "probe_http_status_code{job=~\"$job\", probe_type=\"http\", target_name=\"$target_name\"}",
          "legendFormat": "{{target_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "mode": "none", "group": "A" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0.95 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 7,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Probe Success Rate — $target_name",
      "description": "Five-minute average of probe_success for the selected target. 1.0 means all recent probes succeeded; 0.0 means all recent probes failed. Success is determined by request/transfer errors and expected_status_codes.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "avg_over_time(probe_success{job=~\"$job\", probe_type=\"http\", target_name=\"$target_name\"}[5m])",
          "legendFormat": "success rate (5m avg)",
          "refId": "A"
        }
      ]
    }
  ],
