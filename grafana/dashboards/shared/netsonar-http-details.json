      "title": "Phase Summary - $target_name",
      "description": "Summary of HTTP phase durations for the selected target over the visible time range, excluding hard-timeout results. Failed non-timeout probes are included when they produced phase timings. TOTAL is the sum of phase values for each statistic.",
      "type": "table",
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "phase",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "__name__": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "job": true,
              "job 1": true,
              "job 2": true,
              "instance": true,
              "instance 1": true,
              "instance 2": true,
              "target_name": true,
              "target_name 1": true,
              "target_name 2": true
            },
            "indexByName": {
              "phase": 0,
              "Value #A": 1,
              "Value #B": 2,
              "Value #C": 3
            },
            "renameByName": {
              "phase": "Phase",
              "Value #A": "Last",
              "Value #B": "Mean",
              "Value #C": "Max"
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "sum by (phase) (probe_phase_duration_seconds{job=~\"$job\", probe_type=~\"http|http_body\", target_name=\"$target_name\"} unless on(job, target_name, proxy_name) (probe_timed_out{job=~\"$job\", probe_type=~\"http|http_body\", target_name=\"$target_name\"} == 1)) or label_replace(sum by (target_name) (probe_phase_duration_seconds{job=~\"$job\", probe_type=~\"http|http_body\", target_name=\"$target_name\"} unless on(job, target_name, proxy_name) (probe_timed_out{job=~\"$job\", probe_type=~\"http|http_body\", target_name=\"$target_name\"} == 1)), \"phase\", \"zz_TOTAL\", \"target_name\", \".*\")",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
