      "title": "HTTP Duration — $target_name",
      "description": "Total HTTP probe duration over time for the selected target, excluding hard-timeout results. Failed non-timeout probes are included so slow failures remain visible. Compare with HTTP Phase Timing to see which phase contributed to total latency.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "probe_duration_seconds{job=~\"$job\", probe_type=\"http\", target_name=\"$target_name\"} unless on(job, target_name, proxy_name) (probe_timed_out{job=~\"$job\", probe_type=\"http\", target_name=\"$target_name\"} == 1)",
